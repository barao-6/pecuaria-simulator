<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="theme-color" content="#050e04">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-512.png">
<title>Pecuária Sim — Online</title>
<style>
/* CONFIGURAÇÕES DE DESIGN PROFISSIONAL */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --glass:rgba(10,20,8,0.85);
  --border:rgba(212,160,64,0.3); /* Cor Bronze */
  --green:#3ecf18;--amber:#d4a040;--red:#e03030;
  --text:#f0ffe8;--font:'Segoe UI',system-ui,sans-serif;
}
html,body{height:100%;overflow:hidden;background:#050e04;font-family:var(--font);color:var(--text)}

/* BG LAYER */
#bg-layer{position:fixed;inset:0;z-index:0}
#bg-main{width:100%;height:100%;object-fit:cover;opacity:0.4;filter: contrast(1.1) saturate(0.8);}

/* SPLASH SCREEN */
#splash-screen {
    position: fixed; inset: 0; z-index: 9999; background: #050e04;
    display: flex; align-items: center; justify-content: center; transition: opacity 1s;
}
#splash-screen img { width: min(80vw, 500px); height: auto; }

/* TOPBAR */
#topbar{
    background:rgba(15,30,10,0.95); backdrop-filter:blur(10px);
    border-bottom:1px solid var(--border); padding:10px 15px;
    display:flex; align-items:center; gap:10px; z-index:100;
}
.logo img { height: 35px; vertical-align: middle; }

/* MENU CARDS E IMAGENS */
.banner-img { width: 100%; height: 120px; object-fit: cover; border-radius: 12px; margin-bottom: 15px; border: 1px solid var(--border); }
.card { background: var(--glass); border: 1px solid var(--border); border-radius: 18px; padding: 15px; margin-bottom: 12px; }

/* GADO CARDS */
.sc-photo, .cwc-photo { 
    width: 100%; height: 100%; object-fit: cover; 
    filter: contrast(1.05) saturate(1.1);
}
.cwc { 
    border-radius: 15px; border: 2px solid var(--border); 
    overflow: hidden; aspect-ratio: 1; transition: transform 0.2s;
}
.cwc:active { transform: scale(0.95); }

/* BOTÕES INFERIORES ESTILIZADOS */
#bnav { position: fixed; bottom: 0; width: 100%; background: #0a1408; display: flex; border-top: 1px solid var(--border); padding-bottom: env(safe-area-inset-bottom); }
.bn { flex: 1; padding: 12px 5px; border: none; background: transparent; color: #608050; font-size: 10px; font-weight: bold; text-transform: uppercase; cursor: pointer; }
.bn.on { color: var(--amber); }

/* ESTILO BRONZE PARA BOTÕES */
button.bp { background: linear-gradient(135deg, #d4a040, #8b4513); color: white; border: none; font-weight: 800; text-shadow: 1px 1px 2px rgba(0,0,0,0.5); }

/* REGRAS OCULTAR EMOJIS ANTIGOS */
.emoji-fallback { display: none; }
</style>
</head>
<body>

<div id="splash-screen"><img src="splash.png"></div>

<div id="bg-layer"><img id="bg-main" src="main-bg.png"></div>

<div id="auth-screen" style="position:fixed; inset:0; z-index:1000; display:flex; align-items:center; justify-content:center; padding:20px;">
    <div class="card" style="max-width:400px; width:100%; text-align:center;">
        <img src="logo.png" style="width:200px; margin-bottom:20px;">
        <div id="form-login" style="display:flex; flex-direction:column; gap:10px;">
            <input id="li-user" type="text" placeholder="Usuário ou e-mail" style="padding:12px; border-radius:8px; border:none;">
            <input id="li-pass" type="password" placeholder="Senha" style="padding:12px; border-radius:8px; border:none;">
            <button class="bp" onclick="doLogin()" style="padding:15px; border-radius:8px; cursor:pointer;">ENTRAR NA FAZENDA</button>
        </div>
    </div>
</div>

<div id="shell" style="display:none; flex-direction:column; position:fixed; inset:0;">
    <div id="topbar">
        <div class="logo"><img src="logo.png"></div>
        <div id="hud-row" style="display:flex; gap:10px; flex:1; overflow-x:auto;">
            </div>
    </div>

    <div id="content" style="flex:1; overflow-y:auto; padding:15px; padding-bottom:80px;">
        <div id="p-farm" class="panel on">
            <img src="farm-assets.png" class="banner-img">
            <div class="card">
                <h3>Minha Fazenda</h3>
                <div id="cow-grid" style="display:grid; grid-template-columns: repeat(2, 1fr); gap:10px; margin-top:10px;">
                    </div>
            </div>
        </div>

        <div id="p-mkt" class="panel">
            <img src="market-assets.png" class="banner-img">
            <div id="shop-animais" class="card">
                <h3>Catálogo de Elite</h3>
                <div id="breed-grid" style="display:grid; grid-template-columns:1fr; gap:15px; margin-top:10px;"></div>
            </div>
        </div>
    </div>

    <nav id="bnav">
        <button class="bn on" onclick="switchPanel('farm')">Fazenda</button>
        <button class="bn" onclick="switchPanel('mkt')">Mercado</button>
        <button class="bn" onclick="switchPanel('social')">Social</button>
        <button class="bn" onclick="switchPanel('rank')">Ranking</button>
    </nav>
</div>

<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>

<script>
// CONFIGURAÇÃO DO FIREBASE (Suas chaves reais aqui)
const firebaseConfig = {
  apiKey: "AIzaSyD8eeXfiQs97Fs_hRHmSFc38KGCwcwpVsI",
  authDomain: "pecuaria-sim.firebaseapp.com",
  projectId: "pecuaria-sim",
  storageBucket: "pecuaria-sim.firebasestorage.app",
  messagingSenderId: "561413243877",
  appId: "1:561413243877:web:4ae0978bc7269fd052e50c",
  measurementId: "G-9Z1XMJ539K"
};
firebase.initializeApp(firebaseConfig);

// BANCO DE DADOS DE RAÇAS COM IMAGENS PROFISSIONAIS
const BREEDS = [
  { id:'nelore', name:'Nelore', photo:'nelore.png', type:'beef', price:3200, gen:10, weight:480, desc:'Elite do corte brasileiro.' },
  { id:'angus', name:'Angus', photo:'angus.png', type:'beef', price:5800, gen:22, weight:560, desc:'Carne premium marmorizada.' },
  { id:'holandesa', name:'Holandesa', photo:'holandesa.png', type:'dairy', price:7200, gen:35, weight:620, desc:'Campeã em produção de leite.' },
  { id:'simental', name:'Simental', photo:'simental.png', type:'dual', price:6500, gen:28, weight:600, desc:'Duplo propósito: carne e leite.' },
  { id:'gir', name:'Gir Leiteiro', photo:'gir.png', type:'dairy', price:5500, gen:24, weight:450, desc:'Zebuíno de alta lactação.' },
  { id:'girolando', name:'Girolando', photo:'girolando.png', type:'dairy', price:6800, gen:30, weight:530, desc:'Alta produtividade e rusticidade.' }
];

let G = { money: 15000, cows: [], day: 1 };
let CURRENT_USER = null;

// RENDERIZAR REBANHO (SUBSTITUINDO EMOJIS POR IMAGENS)
function renderFarm() {
    const grid = document.getElementById('cow-grid');
    if (!grid) return;
    grid.innerHTML = G.cows.map(c => {
        const bd = BREEDS.find(b => b.id === c.breedId);
        return `
            <div class="cwc">
                <div style="height:100px; background:#1a2a1a;">
                    <img src="${bd.photo}" class="cwc-photo">
                </div>
                <div style="padding:8px; font-size:11px;">
                    <b>${c.name}</b><br>
                    ⚖️ ${c.weight}kg
                </div>
            </div>
        `;
    }).join('');
}

// RENDERIZAR MERCADO (SUBSTITUINDO EMOJIS POR IMAGENS)
function renderBreedGrid() {
    const el = document.getElementById('breed-grid');
    if (!el) return;
    el.innerHTML = BREEDS.map(b => `
        <div class="card" style="display:flex; gap:15px; align-items:center;">
            <img src="${b.photo}" style="width:80px; height:80px; border-radius:10px; object-fit:cover; border:1px solid var(--border);">
            <div style="flex:1;">
                <h4 style="color:var(--amber)">${b.name}</h4>
                <p style="font-size:10px; opacity:0.8;">${b.desc}</p>
                <button class="bp" onclick="buyAnimal('${b.id}')" style="margin-top:8px; padding:5px 10px; border-radius:5px; font-size:10px;">COMPRAR ${fmt(b.price)}</button>
            </div>
        </div>
    `).join('');
}

// LÓGICA DE LOGIN E ADMIN
async function doLogin() {
    const userVal = document.getElementById('li-user').value;
    // Simulação de login para exemplo (recomenda-se usar Firebase Auth real)
    if(userVal) {
        document.getElementById('auth-screen').style.display = 'none';
        document.getElementById('shell').style.display = 'flex';
        renderBreedGrid();
        setTimeout(() => {
            document.getElementById('splash-screen').style.opacity = '0';
            setTimeout(() => document.getElementById('splash-screen').remove(), 1000);
        }, 1500);
    }
}

function fmt(v) { return 'R$' + v.toLocaleString('pt-BR'); }

// Inicialização
document.addEventListener('DOMContentLoaded', () => {
    console.info('🐄 Pecuária Sim v2.5 — Interface de Elite Pronta!');
});

function switchPanel(name) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('on'));
    document.getElementById('p-' + name).classList.add('on');
    document.querySelectorAll('.bn').forEach(b => b.classList.remove('on'));
    event.currentTarget.classList.add('on');
}
</script>

</body>
</html>
